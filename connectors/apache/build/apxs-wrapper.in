#!@SHELL@
set -e

WRAPPED_OPTS=""
for opt in "$@"; do
    case "$opt" in
        # Fix for -R not working w/apxs
        -R*) WRAPPED_OPTS="$WRAPPED_OPTS -Wl,$opt" ;;
        # OSF1 compiler option
        -pthread) WRAPPED_OPTS="$WRAPPED_OPTS -Wc,$opt" ;;
        # Unwrapped
        *) WRAPPED_OPTS="$WRAPPED_OPTS $opt" ;;
    esac
done

if test -z "$MSCONNECTOR_COMMON_INC" && test -n "$CONNECTOR_ROOT" && test -d "$CONNECTOR_ROOT/common/include"; then
    MSCONNECTOR_COMMON_INC="$CONNECTOR_ROOT/common/include"
fi

if test -z "$MSCONNECTOR_COMMON_INC" && test -d "../../common/include"; then
    MSCONNECTOR_COMMON_INC="../../common/include"
fi

if test -z "$MSCONNECTOR_COMMON_SRC" && test -n "$CONNECTOR_ROOT" && test -d "$CONNECTOR_ROOT/common/src"; then
    MSCONNECTOR_COMMON_SRC="$CONNECTOR_ROOT/common/src"
fi

if test -z "$MSCONNECTOR_COMMON_SRC" && test -d "../../common/src"; then
    MSCONNECTOR_COMMON_SRC="../../common/src"
fi

MSCONNECTOR_COMMON_SOURCES=
if test -n "$MSCONNECTOR_COMMON_SRC"; then
    MSCONNECTOR_COMMON_SOURCE_ROOT=$(CDPATH= cd "$MSCONNECTOR_COMMON_SRC" && pwd)
    MSCONNECTOR_COMMON_BUILD_SRC=${MSCONNECTOR_COMMON_BUILD_SRC:-$(pwd -P)/build/common-src}
    mkdir -p "$MSCONNECTOR_COMMON_BUILD_SRC"
    for common_source in \
        config.c config_parser.c directive_spec.c directive_adapter.c \
        request_helpers.c response_helpers.c request_mapper_contract.c \
        response_mapper_contract.c headers.c event.c event_jsonl.c \
        json_escape.c rule_id.c log_sanitize.c redaction.c \
        resource_limits.c dos_guard.c error.c status.c body_policy.c \
        block_statuses.c http_status.c transaction_state.c late_intervention.c limits.c crs.c
    do
        cp "$MSCONNECTOR_COMMON_SOURCE_ROOT/$common_source" \
            "$MSCONNECTOR_COMMON_BUILD_SRC/$common_source"
    done
    MSCONNECTOR_COMMON_SRC=$MSCONNECTOR_COMMON_BUILD_SRC
    MSCONNECTOR_COMMON_SOURCES="
$MSCONNECTOR_COMMON_SRC/config.c
$MSCONNECTOR_COMMON_SRC/config_parser.c
$MSCONNECTOR_COMMON_SRC/directive_spec.c
$MSCONNECTOR_COMMON_SRC/directive_adapter.c
$MSCONNECTOR_COMMON_SRC/request_helpers.c
$MSCONNECTOR_COMMON_SRC/response_helpers.c
$MSCONNECTOR_COMMON_SRC/request_mapper_contract.c
$MSCONNECTOR_COMMON_SRC/response_mapper_contract.c
$MSCONNECTOR_COMMON_SRC/headers.c
$MSCONNECTOR_COMMON_SRC/event.c
$MSCONNECTOR_COMMON_SRC/event_jsonl.c
$MSCONNECTOR_COMMON_SRC/json_escape.c
$MSCONNECTOR_COMMON_SRC/rule_id.c
$MSCONNECTOR_COMMON_SRC/log_sanitize.c
$MSCONNECTOR_COMMON_SRC/redaction.c
$MSCONNECTOR_COMMON_SRC/resource_limits.c
$MSCONNECTOR_COMMON_SRC/dos_guard.c
$MSCONNECTOR_COMMON_SRC/error.c
$MSCONNECTOR_COMMON_SRC/status.c
$MSCONNECTOR_COMMON_SRC/body_policy.c
$MSCONNECTOR_COMMON_SRC/block_statuses.c
$MSCONNECTOR_COMMON_SRC/http_status.c
$MSCONNECTOR_COMMON_SRC/transaction_state.c
$MSCONNECTOR_COMMON_SRC/late_intervention.c
$MSCONNECTOR_COMMON_SRC/limits.c
$MSCONNECTOR_COMMON_SRC/crs.c"
fi

MSCONNECTOR_COMMON_OPT_I=
if test -n "$MSCONNECTOR_COMMON_INC"; then
    MSCONNECTOR_COMMON_OPT_I="-I $MSCONNECTOR_COMMON_INC"
fi

exec @APXS@ -Wc,-fPIC -Wc,-O0 -a -c -I @V3INCLUDE@ $MSCONNECTOR_COMMON_OPT_I -L @V3LIB@ -lmodsecurity src/mod_security3.c src/msc_config.c src/msc_filters.c src/msc_utils.c src/msc_apache_mapper.c $MSCONNECTOR_COMMON_SOURCES
