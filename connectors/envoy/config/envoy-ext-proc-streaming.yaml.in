# Envoy @ENVOY_RELEASE@ ext_proc streaming configuration template.
#
# This intentionally uses STREAMED (not BUFFERED) body modes. The template is
# not itself evidence; runtime-smoke-envoy-ext-proc materializes it outside the
# checkout and validates that generated configuration with Envoy.
static_resources:
  listeners:
  - name: msconnector_ext_proc_listener
    address:
      socket_address:
        address: 127.0.0.1
        port_value: @LISTEN_PORT@
    filter_chains:
    - filters:
      - name: envoy.filters.network.http_connection_manager
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
          stat_prefix: msconnector_ext_proc_ingress
          route_config:
            name: msconnector_ext_proc_route
            virtual_hosts:
            - name: local_service
              domains: ["*"]
              routes:
              - match:
                  prefix: "/"
                route:
                  cluster: upstream_service
          http_filters:
          - name: envoy.filters.http.ext_proc
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.ext_proc.v3.ExternalProcessor
              grpc_service:
                envoy_grpc:
                  cluster_name: msconnector_ext_proc
                timeout: 0.2s
              processing_mode:
                request_header_mode: SEND
                request_body_mode: STREAMED
                response_header_mode: SEND
                response_body_mode: STREAMED
                # A trailer is the only EOS signal for some streamed HTTP/1.1
                # and HTTP/2 messages. The bridge finalizes the matching
                # Common request/response body when Envoy sends it.
                request_trailer_mode: SEND
                response_trailer_mode: SEND
              # The stream adapter receives these from ProcessingRequest.attributes
              # and maps the real downstream protocol/endpoints into Common Runtime
              # without inferring them from the Envoy-to-service gRPC socket.
              request_attributes:
              - request.protocol
              - source.address
              - source.port
              - destination.address
              - destination.port
              send_body_without_waiting_for_header_response: false
              allow_mode_override: false
              failure_mode_allow: false
              message_timeout: 0.2s
              max_message_timeout: 0.25s
          - name: envoy.filters.http.router
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
  clusters:
  - name: upstream_service
    connect_timeout: 0.5s
    type: STATIC
    load_assignment:
      cluster_name: upstream_service
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address:
                address: 127.0.0.1
                port_value: @UPSTREAM_PORT@
  - name: msconnector_ext_proc
    connect_timeout: 0.5s
    type: STATIC
    http2_protocol_options: {}
    load_assignment:
      cluster_name: msconnector_ext_proc
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address:
                address: 127.0.0.1
                port_value: @EXT_PROC_PORT@
admin:
  access_log_path: /dev/null
  address:
    socket_address:
      address: 127.0.0.1
      port_value: @ADMIN_PORT@
