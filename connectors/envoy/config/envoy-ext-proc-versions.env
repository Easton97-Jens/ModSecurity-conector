# This records the only intended Envoy release for the unpromoted ext_proc
# source/config contract. The pin is not, by itself, runtime evidence; the
# connector-local ext_proc runtime smoke validates a materialized config.
ENVOY_RELEASE=1.38.2
ENVOY_IMAGE=envoyproxy/envoy:v1.38.2
ENVOY_GO_PROTO_MODULE=github.com/envoyproxy/go-control-plane/envoy
ENVOY_GO_PROTO_VERSION=v1.37.0
