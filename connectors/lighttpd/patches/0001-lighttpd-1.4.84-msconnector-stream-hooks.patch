+handler_t
+plugins_call_handle_request_body (request_st * const r,
+                                  const struct chunkqueue * const cq,
+                                  const off_t queue_offset,
+                                  const off_t length,
+                                  const off_t stream_offset,
+                                  const int eos)
+{
+	const void * const plugin_slots = r->con->plugin_slots;
+	const uint32_t offset =
+	  ((const uint16_t *)plugin_slots)[PLUGIN_FUNC_HANDLE_REQUEST_BODY];
+	if (0 == offset) return HANDLER_GO_ON;
+	const plugin_fn_request_body_data *plfd =
+	  (const plugin_fn_request_body_data *)(((uintptr_t)plugin_slots)+offset);
+	handler_t rc = HANDLER_GO_ON;
+	while (plfd->fn
+	       && (rc = plfd->fn(r, cq, queue_offset, length, stream_offset, eos,
+	                          plfd->data)) == HANDLER_GO_ON)
+		++plfd;
+	return rc;
+}
+
+plugin_body_hook_result
+plugins_call_handle_response_body (request_st * const r,
+                                   const struct chunkqueue * const cq,
+                                   const off_t queue_offset,
+                                   const off_t length,
+                                   const off_t stream_offset,
+                                   const int eos)
+{
+	const void * const plugin_slots = r->con->plugin_slots;
+	const uint32_t offset =
+	  ((const uint16_t *)plugin_slots)[PLUGIN_FUNC_HANDLE_RESPONSE_BODY];
+	if (0 == offset) return PLUGIN_BODY_HOOK_CONTINUE;
+	const plugin_fn_response_body_data *plfd =
+	  (const plugin_fn_response_body_data *)(((uintptr_t)plugin_slots)+offset);
+	plugin_body_hook_result rc = PLUGIN_BODY_HOOK_CONTINUE;
+	while (plfd->fn
+	       && (rc = plfd->fn(r, cq, queue_offset, length, stream_offset, eos,
+	                          plfd->data)) == PLUGIN_BODY_HOOK_CONTINUE)
+		++plfd;
+	return rc;
+}
