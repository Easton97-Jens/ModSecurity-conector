+/*
+ * Local ModSecurity ABI bridge: inspect the current HTTP/1.x entity range
+ * before this file adds Transfer-Encoding framing.  The callback receives the
+ * application's borrowed bytes and no lighttpd queue is copied or retained.
+ * Socket short writes and EAGAIN occur later, after this one-time callback,
+ * so they cannot re-submit an entity range to the rule engine.
+ */
+static int
+http_chunk_msconnector_entity_body (request_st * const r,
+                                    const unsigned char * const data,
+                                    const size_t len,
+                                    const int eos)
+{
+    plugin_body_hook_result rc;
+
+    if (r->http_version > HTTP_VERSION_1_1
+        || r->resp_body_entity_hook_eos_sent
+        || r->resp_body_entity_hook_suppressed)
+        return 0;
+    if (0 == len && !eos)
+        return 0;
+    if ((0 != len && NULL == data)
+        || len > (size_t)INT64_MAX
+        || r->resp_body_entity_hook_next_offset
+             > (off_t)(INT64_MAX - (int64_t)len))
+        return -1;
+
+    rc = plugins_call_handle_response_body(r, data, len,
+             r->resp_body_entity_hook_next_offset, eos);
+    if (rc != PLUGIN_BODY_HOOK_CONTINUE)
+        return -1;
+    r->resp_body_entity_hook_next_offset += (off_t)len;
+    if (eos)
+        r->resp_body_entity_hook_eos_sent = 1;
+    return 0;
+}
+
+int
+http_chunk_msconnector_entity_close (request_st * const r)
+{
+    return http_chunk_msconnector_entity_body(r, NULL, 0, 1);
+}
