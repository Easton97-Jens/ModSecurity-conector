# ModSecurity connector local lighttpd extension
#
# Target: lighttpd 1.4.84 source tree only.
# ABI: LIGHTTPD_MSCONNECTOR_STREAM_HOOK_ABI_VERSION=1.
#
# This is deliberately incompatible with stock dynamic modules.  It adds
# synchronous, borrowed request-body and HTTP/1.x pre-socket-write output/EOS
# callbacks.  HTTP/2 is intentionally excluded because its connection queue
# contains multiplexed framed bytes.  The response callback has a cursor so
# EAGAIN and short writes never duplicate an already exposed range.
#
--- a/src/plugin.h
+++ b/src/plugin.h
@@ -5,6 +5,29 @@
 #include "base_decls.h"
 #include "plugin_config.h"
 
+/*
+ * Local ABI extension for the ModSecurity connector patch set.  The source
+ * patch is release-pinned (1.4.84), and its plugin ABI must not mix with a
+ * stock 1.4.84 process or a stock dynamic module: the callback fields below
+ * change sizeof(struct plugin).  Keep the existing version comparison in
+ * plugin.c effective by deriving a distinct version id here, where both the
+ * patched core and every rebuilt module see it.
+ */
+#define LIGHTTPD_MSCONNECTOR_STREAM_HOOK_ABI_VERSION 1
+enum { LIGHTTPD_MSCONNECTOR_BASE_VERSION_ID = LIGHTTPD_VERSION_ID };
+#define LIGHTTPD_MSCONNECTOR_PLUGIN_ABI_VERSION \
+  ((size_t)0x4d530000U | (size_t)LIGHTTPD_MSCONNECTOR_BASE_VERSION_ID)
+#undef LIGHTTPD_VERSION_ID
+#define LIGHTTPD_VERSION_ID LIGHTTPD_MSCONNECTOR_PLUGIN_ABI_VERSION
+
+struct chunkqueue;
+
+typedef enum plugin_body_hook_result {
+	PLUGIN_BODY_HOOK_CONTINUE = 0,
+	PLUGIN_BODY_HOOK_ERROR,
+	PLUGIN_BODY_HOOK_ABORT
+} plugin_body_hook_result;
+
 
 #define SERVER_FUNC(x) \
 		static handler_t x(server *srv, void *p_d)
@@ -68,6 +91,25 @@
 	const char *name;/* name of the plugin */
 	size_t version;
 	void *lib;       /* deprecated; do not use */
+
+	/*
+	 * Borrowed, synchronous body ranges for this local ABI extension.
+	 * queue_offset is relative to cq->first.  stream_offset is monotonic
+	 * within the decoded request body or HTTP/1.x response wire payload.
+	 * Callbacks must not retain pointers, mutate queues, or perform deferred
+	 * access.  The response callback runs immediately before network_write().
+	 * cq may be NULL only for an empty response EOS notification.
+	 */
+	handler_t (* handle_request_body) (request_st *r,
+	                                  const struct chunkqueue *cq,
+	                                  off_t queue_offset, off_t length,
+	                                  off_t stream_offset, int eos,
+	                                  void *p_d);
+	plugin_body_hook_result (* handle_response_body) (request_st *r,
+	                                  const struct chunkqueue *cq,
+	                                  off_t queue_offset, off_t length,
+	                                  off_t stream_offset, int eos,
+	                                  void *p_d);
 };
 typedef struct plugin plugin;
 
