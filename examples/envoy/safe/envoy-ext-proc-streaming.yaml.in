# Envoy @ENVOY_RELEASE@ ext_proc streamed-mode reference.
#
# Materialize this template outside the checkout before using it. The values
# named @...@ are replaced by the connector preparation script, not by Envoy.
static_resources:
  listeners:
  - name: msconnector_ext_proc_listener
    address:
      socket_address:
        address: 127.0.0.1
        port_value: @LISTEN_PORT@
    filter_chains:
    - filters:
      - name: envoy.filters.network.http_connection_manager
        typed_config:
          "@type": type.googleapis.com/envoy.extensions.filters.network.http_connection_manager.v3.HttpConnectionManager
          stat_prefix: msconnector_ext_proc_ingress
          route_config:
            name: msconnector_ext_proc_route
            virtual_hosts:
            - name: local_service
              domains: ["*"]
              routes:
              - match:
                  prefix: "/"
                route:
                  cluster: upstream_service
          http_filters:
          - name: envoy.filters.http.ext_proc
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.ext_proc.v3.ExternalProcessor
              grpc_service:
                envoy_grpc:
                  cluster_name: msconnector_ext_proc
                timeout: 0.2s
              processing_mode:
                # STREAMED is required by the selected Common Runtime bridge.
                request_header_mode: SEND
                request_body_mode: STREAMED
                response_header_mode: SEND
                response_body_mode: STREAMED
                request_trailer_mode: SEND
                response_trailer_mode: SEND
              request_attributes:
              # These attributes supply the request/peer metadata required by the bridge.
              - request.protocol
              - source.address
              - source.port
              - destination.address
              - destination.port
              send_body_without_waiting_for_header_response: false
              allow_mode_override: false
              # Fail closed if the local processor cannot be reached.
              failure_mode_allow: false
              message_timeout: 0.2s
              max_message_timeout: 0.25s
          - name: envoy.filters.http.router
            typed_config:
              "@type": type.googleapis.com/envoy.extensions.filters.http.router.v3.Router
  clusters:
  - name: upstream_service
    connect_timeout: 0.5s
    type: STATIC
    load_assignment:
      cluster_name: upstream_service
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address:
                address: 127.0.0.1
                port_value: @UPSTREAM_PORT@
  - name: msconnector_ext_proc
    connect_timeout: 0.5s
    type: STATIC
    http2_protocol_options: {}
    load_assignment:
      cluster_name: msconnector_ext_proc
      endpoints:
      - lb_endpoints:
        - endpoint:
            address:
              socket_address:
                address: 127.0.0.1
                port_value: @EXT_PROC_PORT@
admin:
  access_log_path: /dev/null
  address:
    socket_address:
      address: 127.0.0.1
      port_value: @ADMIN_PORT@
